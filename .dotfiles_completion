sc_helper_grouped_alias_completion_print_group() {
  local title="$1"
  local group="$2"
  local printed_any="$3"
  local description match printed=0
  shift 3

  for match in "$@"; do
    case "${group}" in
      docker-context)
        case "${match}" in
          d-context*) ;;
          *) continue ;;
        esac
        ;;
      docker-rm)
        case "${match}" in
          d-rm-*) ;;
          *) continue ;;
        esac
        ;;
      docker-other)
        case "${match}" in
          d-context*|d-rm-*) continue ;;
          d-*) ;;
          *) continue ;;
        esac
        ;;
      gcloud-auth)
        case "${match}" in
          gcloud-auth*) ;;
          *) continue ;;
        esac
        ;;
      gcloud-project)
        case "${match}" in
          gcloud-projects|gcloud-set-project) ;;
          *) continue ;;
        esac
        ;;
      gcloud-kubernetes)
        case "${match}" in
          gcloud-kube*) ;;
          *) continue ;;
        esac
        ;;
      gcloud-other)
        case "${match}" in
          gcloud-auth*|gcloud-projects|gcloud-set-project|gcloud-kube*) continue ;;
          gcloud-*) ;;
          *) continue ;;
        esac
        ;;
      git-commit)
        case "${match}" in
          git-commitpush-*) ;;
          *) continue ;;
        esac
        ;;
      git-pull-sync)
        case "${match}" in
          git-pull*|git-sync-*) ;;
          *) continue ;;
        esac
        ;;
      git-inspect)
        case "${match}" in
          git-graph|git-log|git-ref|git-remote|git-show|git-status) ;;
          *) continue ;;
        esac
        ;;
      git-reset)
        case "${match}" in
          git-reset-*) ;;
          *) continue ;;
        esac
        ;;
      git-tag)
        case "${match}" in
          git-tag*) ;;
          *) continue ;;
        esac
        ;;
      git-other)
        case "${match}" in
          git-commitpush-*|git-pull*|git-sync-*|git-graph|git-log|git-ref|git-remote|git-show|git-status|git-reset-*|git-tag*) continue ;;
          git-*) ;;
          *) continue ;;
        esac
        ;;
      sc-dotfiles)
        case "${match}" in
          sc-*) ;;
          *) continue ;;
        esac
        ;;
      *)
        continue
        ;;
    esac

    if [ "${printed}" -eq 0 ]; then
      [ "${printed_any}" -eq 0 ] || printf "\n" >&2
      printf "\033[1m%s:\033[0m\n" "${title}" >&2
      printed=1
    fi
    if description="$(sc_helper_grouped_alias_completion_description "${match}")"; then
      printf "%s — %s\n" "${match}" "${description}" >&2
    else
      printf "%s\n" "${match}" >&2
    fi
  done

  [ "${printed}" -eq 1 ]
}

