sc_helper_ksecret_completion() {
  local cur prev ns secrets namespaces
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  command -v kubectl >/dev/null 2>&1 || return 0

  if [[ "${prev}" == "-n" || "${prev}" == "--namespace" ]]; then
    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  if [[ "${cur}" == --namespace=* ]]; then
    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -P "--namespace=" -W "${namespaces}" -- "${cur#--namespace=}") )
    return 0
  fi

  if [[ "${COMP_WORDS[1]}" == "-n" || "${COMP_WORDS[1]}" == "--namespace" ]]; then
    ns="${COMP_WORDS[2]}"
    [ -n "${ns}" ] || return 0

    if [[ "${COMP_CWORD}" -lt 3 || "${COMP_CWORD}" -gt 3 ]]; then
      return 0
    fi
  else
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default

    if [[ "${COMP_CWORD}" -gt 1 ]]; then
      return 0
    fi
  fi

  if [[ "${cur}" == -* ]]; then
    COMPREPLY=( $(compgen -W "-n --namespace -h --help" -- "${cur}") )
    return 0
  fi

  secrets="$(kubectl get secrets -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
  COMPREPLY=( $(compgen -W "${secrets}" -- "${cur}") )
}

sc_helper_kcontainers_completion() {
  local cur prev ns pods namespaces arg_start arg_pos
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  command -v kubectl >/dev/null 2>&1 || return 0
  if [[ "${COMP_WORDS[1]:-}" == "get" && ( "${COMP_WORDS[2]:-}" == "containers" || "${COMP_WORDS[2]:-}" == "container" ) ]]; then
    arg_start=3
  else
    arg_start=1
  fi
  arg_pos=$((COMP_CWORD - arg_start))

  if [[ "${prev}" == "-n" || "${prev}" == "--namespace" ]]; then
    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  if [[ "${arg_pos}" -lt 0 ]]; then
    return 0
  fi

  if [[ "${COMP_WORDS[arg_start]:-}" == "-n" || "${COMP_WORDS[arg_start]:-}" == "--namespace" ]]; then
    ns="${COMP_WORDS[arg_start+1]:-}"
    [ -n "${ns}" ] || return 0

    if [[ "${arg_pos}" -ne 2 ]]; then
      return 0
    fi
  else
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default

    if [[ "${arg_pos}" -gt 0 ]]; then
      return 0
    fi
  fi

  pods="$(kubectl get pods -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"

  if [[ "${arg_pos}" -eq 0 ]]; then
    if [[ "${cur}" == -* ]]; then
      COMPREPLY=( $(compgen -W "-n --namespace -h --help" -- "${cur}") )
    else
      COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
    fi
  else
    COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
  fi
}

