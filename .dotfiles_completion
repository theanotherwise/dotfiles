sc_helper_strip_completion_file_fallback() {
  local target="$1"
  local spec opt next i last_index
  local -a words opts

  [ -n "${target}" ] || return 0

  spec="$(complete -p "${target}" 2>/dev/null)" || return 0
  case " ${spec} " in
    *" -o default "*|*" -o bashdefault "*) ;;
    *) return 0 ;;
  esac

  read -r -a words <<< "${spec}"
  last_index=$((${#words[@]} - 1))
  [ "${last_index}" -gt 0 ] || return 0

  opts=()
  i=1
  while [ "${i}" -lt "${last_index}" ]; do
    opt="${words[${i}]}"
    case "${opt}" in
      -o)
        next="${words[$((i + 1))]:-}"
        if [ "${next}" != "default" ] && [ "${next}" != "bashdefault" ] && [ -n "${next}" ]; then
          opts+=("${opt}" "${next}")
        fi
        i=$((i + 2))
        ;;
      -A|-G|-W|-P|-S|-X|-F|-C)
        next="${words[$((i + 1))]:-}"
        [ -n "${next}" ] && opts+=("${opt}" "${next}")
        i=$((i + 2))
        ;;
      *)
        opts+=("${opt}")
        i=$((i + 1))
        ;;
    esac
  done

  complete -r "${target}" 2>/dev/null || true
  complete "${opts[@]}" "${target}"
}

sc_helper_source_cached_completion() {
  local cmd="$1"
  local cmd_path cache_file tmp_file lock_dir pid ticks restore_monitor
  shift || return 0

  [ -n "${cmd}" ] || return 0
  [ "$#" -gt 0 ] || set -- completion bash

  cmd_path="$(type -P "${cmd}" 2>/dev/null)" || return 0
  cache_file="${SC_BASH_COMPLETION_CACHE_DIR}/${cmd}.bash"

  if [ -s "${cache_file}" ]; then
    . "${cache_file}"
    sc_helper_strip_completion_file_fallback "${cmd}"
    return 0
  fi

  tmp_file="${cache_file}.tmp.$$"
  lock_dir="${cache_file}.lock"

  if [ -n "${SC_BASH_COMPLETION_CACHE_ASYNC:-}" ]; then
    if ! command mkdir "${lock_dir}" 2>/dev/null; then
      sc_helper_completion_cache_log "locked" "${cmd}" "${cache_file}"
      return 0
    fi

    sc_helper_completion_cache_log "queued" "${cmd}" "${cache_file}"
    (
      trap 'command rm -f "${tmp_file}"; command rmdir "${lock_dir}" 2>/dev/null || true' EXIT

      "${cmd_path}" "$@" >"${tmp_file}" 2>/dev/null &
      pid=$!
      ticks=0

      while kill -0 "${pid}" 2>/dev/null; do
        ticks=$((ticks + 1))
        if [ "${ticks}" -ge "${SC_BASH_COMPLETION_TIMEOUT_TENTHS}" ]; then
          kill "${pid}" >/dev/null 2>&1 || true
          wait "${pid}" 2>/dev/null || true
          command rm -f "${tmp_file}"
          exit 0
        fi
        sleep 0.1
      done

      if wait "${pid}" 2>/dev/null && [ -s "${tmp_file}" ]; then
        command mv "${tmp_file}" "${cache_file}"
      else
        command rm -f "${tmp_file}"
      fi
    ) &
    disown "$!" 2>/dev/null || true
    return 0
  fi

  sc_helper_completion_cache_log "generate" "${cmd}" "${cache_file}"

  if ! command mkdir "${lock_dir}" 2>/dev/null; then
    sc_helper_completion_cache_log "locked" "${cmd}" "${cache_file}"
    return 0
  fi

  restore_monitor=0
  case "$-" in
    *m*)
      restore_monitor=1
      set +m
      ;;
  esac

  "${cmd_path}" "$@" >"${tmp_file}" 2>/dev/null &
  pid=$!
  ticks=0

  # Avoid blocking shell startup forever on a broken completion command.
  while kill -0 "${pid}" 2>/dev/null; do
    ticks=$((ticks + 1))
    if [ "${ticks}" -ge "${SC_BASH_COMPLETION_TIMEOUT_TENTHS}" ]; then
      kill "${pid}" >/dev/null 2>&1 || true
          wait "${pid}" 2>/dev/null || true
          [ "${restore_monitor}" -eq 0 ] || set -m
          command rm -f "${tmp_file}"
          command rmdir "${lock_dir}" 2>/dev/null || true
          return 0
        fi
    sleep 0.1
  done

  if ! wait "${pid}" 2>/dev/null; then
    [ "${restore_monitor}" -eq 0 ] || set -m
    command rm -f "${tmp_file}"
    command rmdir "${lock_dir}" 2>/dev/null || true
    return 0
  fi

  [ "${restore_monitor}" -eq 0 ] || set -m

  if [ -s "${tmp_file}" ]; then
    command mv "${tmp_file}" "${cache_file}"
    . "${cache_file}"
    sc_helper_strip_completion_file_fallback "${cmd}"
  else
    command rm -f "${tmp_file}"
  fi

  command rmdir "${lock_dir}" 2>/dev/null || true
}

