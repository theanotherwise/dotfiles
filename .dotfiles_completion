sc_helper_ksecret_completion() {
  local cur prev ns secrets namespaces
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  command -v kubectl >/dev/null 2>&1 || return 0

  if [[ "${prev}" == "-n" || "${prev}" == "--namespace" ]]; then
    if declare -F sc_helper_kube_namespaces_completion >/dev/null 2>&1; then
      sc_helper_kube_namespaces_completion
      return 0
    fi

    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  if [[ "${COMP_WORDS[1]}" == "-n" || "${COMP_WORDS[1]}" == "--namespace" ]]; then
    ns="${COMP_WORDS[2]}"
    [ -n "${ns}" ] || return 0

    if [[ "${COMP_CWORD}" -lt 3 || "${COMP_CWORD}" -gt 3 ]]; then
      return 0
    fi
  else
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default

    if [[ "${COMP_CWORD}" -gt 1 ]]; then
      return 0
    fi
  fi

  if [[ "${cur}" == -* ]]; then
    COMPREPLY=( $(compgen -W "-n --namespace -h --help" -- "${cur}") )
    return 0
  fi

  secrets="$(kubectl get secrets -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
  COMPREPLY=( $(compgen -W "${secrets}" -- "${cur}") )
}

sc_helper_kcontainers_completion() {
  local cur prev ns pods namespaces
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  command -v kubectl >/dev/null 2>&1 || return 0

  if [[ "${prev}" == "-n" ]]; then
    if declare -F sc_helper_kube_namespaces_completion >/dev/null 2>&1; then
      sc_helper_kube_namespaces_completion
      return 0
    fi

    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  if [[ "${COMP_WORDS[1]}" == "-n" ]]; then
    ns="${COMP_WORDS[2]}"
    [ -n "${ns}" ] || return 0

    # kcontainers -n <namespace> <pod>
    if [[ "${COMP_CWORD}" -lt 3 ]]; then
      return 0
    fi
  else
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default

    # Keep completion focused on the single pod argument for this helper.
    if [[ "${COMP_CWORD}" -gt 1 ]]; then
      return 0
    fi
  fi

  pods="$(kubectl get pods -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"

  if [[ "${COMP_CWORD}" -eq 1 ]]; then
    if [[ "${cur}" == -* ]]; then
      COMPREPLY=( $(compgen -W "-n" -- "${cur}") )
    else
      COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
    fi
  else
    COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
  fi
}

sc_helper_kerrors_completion() {
  local cur prev word namespaces pods ns has_namespace_value has_pod has_all expect_namespace
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  for word in "${COMP_WORDS[@]:1:COMP_CWORD-1}"; do
    case "${word}" in
      -A|--all-namespaces)
        has_all=1
        ;;
    esac
  done

  if [[ "${has_all}" == "1" ]]; then
    if [[ "${cur}" == -* ]]; then
      COMPREPLY=( $(compgen -W "-h --help" -- "${cur}") )
    fi
    return 0
  fi

  if [[ "${prev}" == "-n" || "${prev}" == "--namespace" ]]; then
    if declare -F sc_helper_kube_namespaces_completion >/dev/null 2>&1; then
      sc_helper_kube_namespaces_completion
      return 0
    fi

    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  for word in "${COMP_WORDS[@]:1:COMP_CWORD-1}"; do
    case "${word}" in
      -n|--namespace)
        expect_namespace=1
        ;;
      *)
        if [[ "${expect_namespace}" == "1" ]]; then
          ns="${word}"
          has_namespace_value=1
          expect_namespace=0
        elif [[ "${word}" != -* ]]; then
          has_pod=1
        fi
        ;;
    esac
  done

  if [[ "${has_pod}" == "1" ]]; then
    return 0
  fi

  if [[ "${cur}" == -* ]]; then
    COMPREPLY=( $(compgen -W "-A --all-namespaces -n --namespace -h --help" -- "${cur}") )
    return 0
  fi

  if [[ "${has_namespace_value}" != "1" ]]; then
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default
  fi

  pods="$(kubectl get pods -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
  COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
}

sc_helper_atuin_a_completion() {
  declare -F _atuin >/dev/null 2>&1 || return 0

  local original_cword cur prev
  local -a original_words

  original_cword="${COMP_CWORD}"
  original_words=("${COMP_WORDS[@]}")

  COMP_WORDS=(atuin search -i "${original_words[@]:1}")
  COMP_CWORD=$((original_cword + 2))
  cur="${COMP_WORDS[COMP_CWORD]}"
  if [ "${COMP_CWORD}" -gt 0 ]; then
    prev="${COMP_WORDS[COMP_CWORD-1]}"
  else
    prev=""
  fi
  _atuin atuin "${cur}" "${prev}"

  COMP_WORDS=("${original_words[@]}")
  COMP_CWORD="${original_cword}"
}

sc_helper_gitconfig_completion_redraw() {
  local prompt line user_name host_name cwd_name cursor branch

  line="${COMP_LINE:-}"
  if ((BASH_VERSINFO[0] >= 5 || BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4)); then
    prompt=${PS1@P}
    prompt=${prompt//[$'\001\002']}
  else
    user_name="${USER:-$(id -un 2>/dev/null)}"
    host_name="${HOSTNAME%%.*}"
    [ -n "${host_name}" ] || host_name="$(hostname -s 2>/dev/null || hostname 2>/dev/null)"
    case "${PWD}" in
      "${HOME}") cwd_name="~" ;;
      /) cwd_name="/" ;;
      *) cwd_name="${PWD##*/}" ;;
    esac
    if declare -F sc_helper_bashrc_cursor >/dev/null 2>&1; then
      cursor="$(sc_helper_bashrc_cursor)"
    elif [ "${UID}" = "0" ]; then
      cursor="#"
    else
      cursor="$"
    fi
    if declare -F sc_helper_bashrc_branch >/dev/null 2>&1; then
      branch="$(sc_helper_bashrc_branch)"
    else
      branch=""
    fi
    prompt="[${user_name}]@[${host_name}][${cwd_name}]${cursor} ${branch}"
  fi

  printf "%s%s" "${prompt}" "${line}" >&2
}

sc_helper_gitconfig_completion() {
  local cur key name email count
  local -a matches

  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"

  if [[ "${COMP_CWORD}" -gt 1 ]]; then
    return 0
  fi

  declare -F sc_helper_gitconfig_profiles >/dev/null 2>&1 || return 0

  while IFS=$'\t' read -r key name email; do
    case "${key}" in
      "${cur}"*)
        matches+=("${key}"$'\t'"${name}"$'\t'"${email}")
        ;;
    esac
  done < <(sc_helper_gitconfig_profiles)

  case "list" in
    "${cur}"*)
      matches+=("list"$'\t'"show all git identity profiles"$'\t'"")
      ;;
  esac

  count="${#matches[@]}"
  if [ "${count}" -eq 0 ]; then
    printf "\n" >&2
    printf "No gitconfig profiles match: %s\n" "${cur}" >&2
    sc_helper_gitconfig_completion_redraw
    return 0
  fi

  if [ "${count}" -eq 1 ]; then
    IFS=$'\t' read -r key name email <<< "${matches[0]}"
    COMPREPLY=("${key}")
    return 0
  fi

  printf "\n" >&2
  for match in "${matches[@]}"; do
    IFS=$'\t' read -r key name email <<< "${match}"
    if [ "${key}" = "list" ]; then
      printf "%-8s %s\n" "${key}" "${name}" >&2
    else
      printf "%-8s (%s) %s\n" "${key}" "${email}" "${name}" >&2
    fi
  done
  sc_helper_gitconfig_completion_redraw
}

