sc_helper_kerrors_completion() {
  local cur prev word namespaces pods ns has_namespace_value has_pod has_all expect_namespace expect_tail expect_since
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  for word in "${COMP_WORDS[@]:1:COMP_CWORD-1}"; do
    case "${word}" in
      -A|--all-namespaces)
        has_all=1
        ;;
	    esac
  done

  if [[ "${prev}" == "--tail" || "${prev}" == "-s" || "${prev}" == "--since" ]]; then
    return 0
  fi

  if [[ "${prev}" == "-n" || "${prev}" == "--namespace" ]]; then
    if declare -F sc_helper_kube_namespaces_completion >/dev/null 2>&1; then
      sc_helper_kube_namespaces_completion
      return 0
    fi

    namespaces="$(kubectl get namespaces -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
    COMPREPLY=( $(compgen -W "${namespaces}" -- "${cur}") )
    return 0
  fi

  for word in "${COMP_WORDS[@]:1:COMP_CWORD-1}"; do
    case "${word}" in
      --tail)
        expect_tail=1
        ;;
      --tail=*)
        ;;
      -s|--since)
        expect_since=1
        ;;
      --since=*)
        ;;
      -l|--logs|--sort|-p|--previous|-h|--help)
        ;;
      -n|--namespace)
        expect_namespace=1
        ;;
      *)
        if [[ "${expect_namespace}" == "1" ]]; then
          ns="${word}"
          has_namespace_value=1
          expect_namespace=0
        elif [[ "${expect_tail}" == "1" ]]; then
          expect_tail=0
        elif [[ "${expect_since}" == "1" ]]; then
          expect_since=0
        elif [[ "${word}" != -* ]]; then
          has_pod=1
        fi
        ;;
    esac
  done

  if [[ "${cur}" == -* ]]; then
    if [[ "${has_all}" == "1" ]]; then
      COMPREPLY=( $(compgen -W "-l --logs --sort -p --previous -s --since --tail -h --help" -- "${cur}") )
    else
      COMPREPLY=( $(compgen -W "-A --all-namespaces -n --namespace -l --logs --sort -p --previous -s --since --tail -h --help" -- "${cur}") )
    fi
    return 0
  fi

  if [[ "${has_pod}" == "1" || "${has_all}" == "1" ]]; then
    return 0
  fi

  if [[ "${has_namespace_value}" != "1" ]]; then
    ns="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null)"
    [ -n "${ns}" ] || ns=default
  fi

  pods="$(kubectl get pods -n "${ns}" -o jsonpath='{range .items[*]}{.metadata.name}{" "}{end}' 2>/dev/null)"
  COMPREPLY=( $(compgen -W "${pods}" -- "${cur}") )
}

sc_helper_atuin_a_completion() {
  declare -F _atuin >/dev/null 2>&1 || return 0

  local original_cword cur prev
  local -a original_words

  original_cword="${COMP_CWORD}"
  original_words=("${COMP_WORDS[@]}")

  COMP_WORDS=(atuin search -i "${original_words[@]:1}")
  COMP_CWORD=$((original_cword + 2))
  cur="${COMP_WORDS[COMP_CWORD]}"
  if [ "${COMP_CWORD}" -gt 0 ]; then
    prev="${COMP_WORDS[COMP_CWORD-1]}"
  else
    prev=""
  fi
  _atuin atuin "${cur}" "${prev}"

  COMP_WORDS=("${original_words[@]}")
  COMP_CWORD="${original_cword}"
}

sc_helper_gitconfig_completion_redraw() {
  local prompt line user_name host_name cwd_name cursor branch

  line="${COMP_LINE:-}"
  if ((BASH_VERSINFO[0] >= 5 || BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4)); then
    prompt=${PS1@P}
    prompt=${prompt//[$'\001\002']}
  else
    user_name="${USER:-$(id -un 2>/dev/null)}"
    host_name="${HOSTNAME%%.*}"
    [ -n "${host_name}" ] || host_name="$(hostname -s 2>/dev/null || hostname 2>/dev/null)"
    case "${PWD}" in
      "${HOME}") cwd_name="~" ;;
      /) cwd_name="/" ;;
      *) cwd_name="${PWD##*/}" ;;
    esac
    if declare -F sc_helper_bashrc_cursor >/dev/null 2>&1; then
      cursor="$(sc_helper_bashrc_cursor)"
    elif [ "${UID}" = "0" ]; then
      cursor="#"
    else
      cursor="$"
    fi
    if declare -F sc_helper_bashrc_branch >/dev/null 2>&1; then
      branch="$(sc_helper_bashrc_branch)"
    else
      branch=""
    fi
    prompt="[${user_name}]@[${host_name}][${cwd_name}]${cursor} ${branch}"
  fi

  printf "%s%s" "${prompt}" "${line}" >&2
}

