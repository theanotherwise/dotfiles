sc_helper_grouped_alias_completion_common_prefix() {
  local prefix candidate

  [ "$#" -gt 0 ] || return 1
  prefix="$1"
  shift

  for candidate in "$@"; do
    while [ -n "${prefix}" ]; do
      case "${candidate}" in
        "${prefix}"*) break ;;
      esac
      prefix="${prefix%?}"
    done
    [ -n "${prefix}" ] || break
  done

  printf "%s\n" "${prefix}"
}

sc_helper_grouped_alias_completion() {
  local common_prefix cur count key match
  local -a matches commands

  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"

  case "${cur}" in
    d-*|gcloud-*|git-*|sc-*)
      while IFS= read -r match; do
        [ -n "${match}" ] || continue
        matches+=("${match}")
      done < <(compgen -A alias -- "${cur}" | sort)

      count="${#matches[@]}"
      if [ "${count}" -eq 0 ]; then
        SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY=""
        return 0
      fi

      if [ "${count}" -eq 1 ]; then
        SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY=""
        COMPREPLY=("${matches[0]}")
        return 0
      fi

      common_prefix="$(sc_helper_grouped_alias_completion_common_prefix "${matches[@]}")"
      if [ "${#common_prefix}" -gt "${#cur}" ]; then
        SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY=""
        COMPREPLY=("${matches[@]}")
        compopt -o nospace 2>/dev/null || true
        return 0
      fi

      key="${COMP_LINE:-}:${COMP_POINT:-}:${cur}"
      if [ "${SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY:-}" != "${key}" ]; then
        SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY="${key}"
        return 0
      fi

      printf "\n" >&2
      sc_helper_grouped_alias_completion_print_matches "${cur}" "${matches[@]}"
      sc_helper_completion_redraw
      return 0
      ;;
  esac

  SC_HELPER_GROUPED_ALIAS_COMPLETION_LAST_KEY=""
  while IFS= read -r match; do
    [ -n "${match}" ] || continue
    commands+=("${match}")
  done < <(
    {
      compgen -A alias -- "${cur}"
      compgen -A function -- "${cur}"
      compgen -A builtin -- "${cur}"
      compgen -A command -- "${cur}"
      compgen -A keyword -- "${cur}"
    } | sort -u
  )

  COMPREPLY=("${commands[@]}")
}

sc_helper_gitconfig_completion() {
  local cur key name email count
  local -a matches

  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"

  if [[ "${COMP_CWORD}" -gt 1 ]]; then
    return 0
  fi

  declare -F sc_helper_gitconfig_profiles >/dev/null 2>&1 || return 0

  while IFS=$'\t' read -r key name email; do
    case "${key}" in
      "${cur}"*)
        matches+=("${key}"$'\t'"${name}"$'\t'"${email}")
        ;;
    esac
  done < <(sc_helper_gitconfig_profiles)

  case "list" in
    "${cur}"*)
      matches+=("list"$'\t'"show all git identity profiles"$'\t'"")
      ;;
  esac

  count="${#matches[@]}"
  if [ "${count}" -eq 0 ]; then
    printf "\n" >&2
    printf "No gitconfig profiles match: %s\n" "${cur}" >&2
    sc_helper_gitconfig_completion_redraw
    return 0
  fi

  if [ "${count}" -eq 1 ]; then
    IFS=$'\t' read -r key name email <<< "${matches[0]}"
    COMPREPLY=("${key}")
    return 0
  fi

  printf "\n" >&2
  for match in "${matches[@]}"; do
    IFS=$'\t' read -r key name email <<< "${match}"
    if [ "${key}" = "list" ]; then
      printf "%-8s %s\n" "${key}" "${name}" >&2
    else
      printf "%-8s (%s) %s\n" "${key}" "${email}" "${name}" >&2
    fi
  done
  sc_helper_gitconfig_completion_redraw
}

